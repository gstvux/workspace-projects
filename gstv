#!/usr/bin/env bash
# CLI Centralizado e Configurável de Automação (gstv)

# 1. Resolução dinâmica do diretório do projeto (suporta links simbólicos)
REAL_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
PROJECT_ROOT="$(cd "$(dirname "$REAL_PATH")" && pwd)"
SCRIPTS_DIR="$PROJECT_ROOT/scripts"

CONFIG_FILE="$PROJECT_ROOT/project.yaml"
DEFAULT_CLI_NAME="gstv"

# 2. Parser nativo de YAML para extrair a chave 'cli_command'
if [ -f "$CONFIG_FILE" ]; then
    # Extrai o valor de cli_command ignorando espaços e aspas opcionais
    CLI_NAME=$(grep -E "^cli_command:" "$CONFIG_FILE" | head -n 1 | sed -E 's/^cli_command:[[:space:]]*["'\'']?([^"'\''[:space:]]+)["'\'']?.*$/\1/')
fi

# Fallback caso não encontre ou esteja vazio
[ -z "$CLI_NAME" ] && CLI_NAME="$DEFAULT_CLI_NAME"

# Função para registrar/linkar o CLI no PATH do usuário e limpar links obsoletos
relink_cli() {
    local bin_dir="$HOME/.local/bin"
    
    # Garante que a pasta bin do usuário existe
    mkdir -p "$bin_dir"
    
    # --- GARBAGE COLLECTOR DE LINKS ANTIGOS ---
    # Varre a pasta bin para encontrar QUALQUER link antigo apontando para este exato script
    # e remove-o, garantindo que não deixamos lixo órfão no sistema.
    if [ -d "$bin_dir" ]; then
        for symlink in "$bin_dir"/*; do
            if [ -L "$symlink" ]; then
                local target
                target="$(readlink -f "$symlink")"
                if [ "$target" == "$REAL_PATH" ]; then
                    local sl_name
                    sl_name="$(basename "$symlink")"
                    # Se o link aponta para cá mas tem nome diferente do configurado no YAML, deleta
                    if [ "$sl_name" != "$CLI_NAME" ]; then
                        echo -e "🧹 Limpando link antigo obsoleto apontando para cá: \033[31m$symlink\033[0m"
                        rm -f "$symlink"
                    fi
                fi
            fi
        done
    fi
    # ------------------------------------------
    
    # Cria o novo link simbólico apontando para ESTE script 'gstv'
    ln -sf "$REAL_PATH" "$bin_dir/$CLI_NAME"
    
    echo -e "\033[1;32m[OK] CLI registrado com sucesso!\033[0m"
    echo -e "🔗 Link criado: \033[33m$bin_dir/$CLI_NAME\033[0m -> \033[33m$REAL_PATH\033[0m"
    echo -e "🚀 Agora você pode rodar \033[1;34m$CLI_NAME <comando>\033[0m de qualquer lugar do seu terminal!"
    
    # Alerta caso ~/.local/bin não esteja no PATH
    if [[ ":$PATH:" != *":$bin_dir:"* ]]; then
        echo -e "\033[1;33m[AVISO] A pasta $bin_dir não está no seu PATH do sistema.\033[0m"
        echo -e "Adicione a seguinte linha ao seu ~/.bashrc ou ~/.zshrc:"
        echo -e "  \033[36mexport PATH=\"\$HOME/.local/bin:\$PATH\"\033[0m"
    fi
}

show_help() {
    echo -e "\033[1;36m==================================================\033[0m"
    echo -e "\033[1;32m         CLI: $CLI_NAME (Projeto: $(basename "$PROJECT_ROOT")) \033[0m"
    echo -e "\033[1;36m==================================================\033[0m"
    echo -e "Uso: \033[33m$CLI_NAME <comando> [argumentos]\033[0m\n"
    echo -e "Comandos do CLI:"
    printf "  \033[1;32m%-15s\033[0m - %s\n" "relink" "Atualiza e registra este CLI globalmente como '$CLI_NAME'"
    echo -e "\nComandos disponíveis em 'scripts/':"
    
    # Busca dinamicamente os scripts executáveis
    for script_path in "$SCRIPTS_DIR"/*; do
        if [ -f "$script_path" ] && [ -x "$script_path" ]; then
            cmd_name="$(basename "$script_path")"
            description=$(grep -m 1 "^# description:" "$script_path" | cut -d':' -f2- | sed 's/^[ \t]*//')
            [ -z "$description" ] && description="Nenhuma descrição fornecida."
            printf "  \033[1;34m%-15s\033[0m - %s\n" "$cmd_name" "$description"
        fi
    done
    echo -e "\033[1;36m==================================================\033[0m"
}

# Se for o comando especial de linkagem
if [ "$1" == "relink" ]; then
    relink_cli
    exit 0
fi

# Se não passar argumentos ou pedir ajuda
if [ $# -eq 0 ] || [ "$1" == "-h" ] || [ "$1" == "--help" ]; then
    show_help
    exit 0
fi

CMD="$1"
shift
TARGET_SCRIPT="$SCRIPTS_DIR/$CMD"

if [ -f "$TARGET_SCRIPT" ] && [ -x "$TARGET_SCRIPT" ]; then
    exec "$TARGET_SCRIPT" "$@"
else
    echo -e "\033[1;31m[ERRO] Comando '$CMD' não encontrado ou não executável.\033[0m"
    echo -e "Use \033[33m$CLI_NAME --help\033[0m para ver os comandos disponíveis."
    exit 1
fi
